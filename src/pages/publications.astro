---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('publications')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Publications | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Conference and journal contributions in quantum machine learning and related topics."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Publications"
				tagline="Research outputs in quantum machine learning and computational science."
				align="start"
			/>
			<Grid variant="offset">
				{
					entries.map((entry) => (
						<li>
							<PortfolioPreview entry={entry} hrefBase="/publications" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

