---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="About | Mahdi Sadrnezhaad"
	description="About Mahdi Sadrnezhaad and the work shared on this site."
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. This is the place for a short bio, background, and the story behind the work."
			>
				<img
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Workspace photo placeholder"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						This site is built with <a href="https://astro.build/">Astro</a> and ready to host on
						GitHub Pages. Use this section to introduce who you are, what you do, and the kinds of
						problems you like working on.
					</p>
					<p>
						Add a few concrete details: your current focus, the tools you enjoy, the domains you
						care about, and the outcomes you are proud of.
					</p>
					<p>
						When you are ready, replace the starter images in <code>public/assets</code> with your own
						photos and update the project entries in <code>src/content/work</code>.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Focus</h2>
				<div class="content">
					<p>Software, product thinking, and practical experiments that become useful tools.</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p>Replace this with the technologies, practices, and strengths you want people to notice.</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
