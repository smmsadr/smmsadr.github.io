---
import ContactCTA from '../components/ContactCTA.astro';
import Icon from '../components/Icon.astro';
import Timeline from '../components/Timeline.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="About | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Senior Quantitative Engineer and Data Scientist based in Kuala Lumpur, working at the intersection of optimization, AI, scientific computing, and quantum machine learning."
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<section class="about-hero" aria-labelledby="about-hero-title">
				<div class="about-hero-bg" aria-hidden="true">
					<div class="about-hero-gradient"></div>
					<div class="about-hero-noise"></div>
				</div>

				<!-- Floating accent glyphs: math ∑, optimization ⟶, AI ◇, quantum |ψ⟩ -->
				<div class="about-hero-accents" aria-hidden="true">
					<span class="accent accent-1">∑</span>
					<span class="accent accent-2">∇</span>
					<span class="accent accent-3">⟶</span>
					<span class="accent accent-4">◇</span>
					<span class="accent accent-5">|ψ⟩</span>
					<span class="accent accent-6">π</span>
					<span class="accent accent-7">∫</span>
					<span class="accent accent-8">⟨φ|</span>
				</div>

				<div class="about-hero-content">
					<p class="about-eyebrow">About</p>
					<h1 id="about-hero-title" class="about-title">
						Building systems that transform<br />
						complexity into decisions.
					</h1>
					<p class="about-lede">
						I am a Senior Quantitative Engineer and Data Scientist based in Kuala Lumpur,
						working at the intersection of optimization, artificial intelligence, scientific
						computing, and quantum machine learning. My work combines mathematical modelling,
						software engineering, and systems thinking to build reliable decision systems
						for real-world problems.
					</p>
				</div>

				<div class="about-hero-portrait">
					<img
						width="1553"
						height="873"
						src="/assets/Mahdi-AboutMe.png"
						alt="Sayed Mohammad Mahdi Sadrnezhaad"
					/>
				</div>
			</section>

			<section class="my-story" aria-labelledby="my-story-title">
				<header class="story-header">
					<p class="story-eyebrow">My Journey</p>
					<h2 id="my-story-title" class="story-title">
						From Physics to Intelligent Systems
					</h2>
				</header>

				<div class="story-divider" aria-hidden="true">
					<span class="story-divider-line"></span>
					<span class="story-divider-dot"></span>
					<span class="story-divider-line"></span>
				</div>

				<div class="story-body">
					<p>
						My journey began in physics, where I became fascinated by understanding
						complex systems through mathematics. That curiosity gradually expanded into
						software engineering, optimization, machine learning, and eventually quantum
						computing.
					</p>
					<p>
						Today I design decision systems that combine rigorous mathematical models with
						modern AI to solve practical problems across forecasting, optimization, hybrid
						intelligence, and scientific computing.
					</p>
				</div>

				<ul class="story-chapters" aria-label="Fields that shaped my path">
					<li class="chapter">
						<span class="chapter-icon" aria-hidden="true">
							<Icon icon="atom" color="var(--accent-regular)" size="1.4rem" gradient />
						</span>
						<span class="chapter-label">Physics</span>
					</li>
					<li class="chapter-arrow" aria-hidden="true">→</li>
					<li class="chapter">
						<span class="chapter-icon" aria-hidden="true">
							<Icon icon="code" color="var(--accent-regular)" size="1.4rem" gradient />
						</span>
						<span class="chapter-label">Software</span>
					</li>
					<li class="chapter-arrow" aria-hidden="true">→</li>
					<li class="chapter">
						<span class="chapter-icon" aria-hidden="true">
							<Icon icon="chart-line-up" color="var(--accent-regular)" size="1.4rem" gradient />
						</span>
						<span class="chapter-label">Optimization</span>
					</li>
					<li class="chapter-arrow" aria-hidden="true">→</li>
					<li class="chapter">
						<span class="chapter-icon" aria-hidden="true">
							<Icon icon="cpu" color="var(--accent-regular)" size="1.4rem" gradient />
						</span>
						<span class="chapter-label">AI &amp; Quantum</span>
					</li>
				</ul>
			</section>

			<section class="how-i-think" aria-labelledby="how-i-think-title">
				<header class="think-header">
					<p class="think-eyebrow">How I Think</p>
					<h2 id="how-i-think-title" class="think-title">
						The principles that guide every system I build.
					</h2>
				</header>

				<ol class="think-grid">
					<li class="think-card" tabindex="0">
						<div class="think-icon" aria-hidden="true">
							<Icon icon="moon-stars" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="think-card-title">Curiosity</h3>
						<p class="think-card-desc">
							I begin by asking better questions before searching for better answers.
						</p>
					</li>

					<li class="think-card" tabindex="0">
						<div class="think-icon" aria-hidden="true">
							<Icon icon="strategy" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="think-card-title">Systems Thinking</h3>
						<p class="think-card-desc">
							Every component matters, but interactions matter even more.
						</p>
					</li>

					<li class="think-card" tabindex="0">
						<div class="think-icon" aria-hidden="true">
							<Icon icon="calculator" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="think-card-title">Mathematics</h3>
						<p class="think-card-desc">
							Good models simplify reality without losing truth.
						</p>
					</li>

					<li class="think-card" tabindex="0">
						<div class="think-icon" aria-hidden="true">
							<Icon icon="code" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="think-card-title">Engineering</h3>
						<p class="think-card-desc">
							Ideas only matter when they become reliable systems.
						</p>
					</li>

					<li class="think-card" tabindex="0">
						<div class="think-icon" aria-hidden="true">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="think-card-title">Continuous Learning</h3>
						<p class="think-card-desc">
							Every project is another opportunity to improve.
						</p>
					</li>
				</ol>
			</section>
			<section class="capabilities" aria-labelledby="capabilities-title">
				<header class="cap-header">
					<p class="cap-eyebrow">Capabilities</p>
					<h2 id="capabilities-title" class="cap-title">
						Technologies, research areas, and engineering practices I use daily.
					</h2>
				</header>

				<ol class="cap-grid">
					<li class="cap-card">
						<div class="cap-icon" aria-hidden="true">
							<Icon icon="code" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="cap-card-title">Programming</h3>
						<ul class="cap-tags">
							<li>Python</li>
							<li>SQL</li>
							<li>JavaScript</li>
							<li>Fortran</li>
						</ul>
					</li>

					<li class="cap-card">
						<div class="cap-icon" aria-hidden="true">
							<Icon icon="cpu" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="cap-card-title">Artificial Intelligence</h3>
						<ul class="cap-tags">
							<li>Machine Learning</li>
							<li>LLMs</li>
							<li>LangGraph</li>
							<li>Optimization</li>
							<li>Hybrid AI</li>
						</ul>
					</li>

					<li class="cap-card">
						<div class="cap-icon" aria-hidden="true">
							<Icon icon="calculator" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="cap-card-title">Mathematical Computing</h3>
						<ul class="cap-tags">
							<li>Pyomo</li>
							<li>GAMS</li>
							<li>CPLEX</li>
							<li>IPOPT</li>
							<li>SciPy</li>
							<li>NumPy</li>
							<li>Polars</li>
						</ul>
					</li>

					<li class="cap-card">
						<div class="cap-icon" aria-hidden="true">
							<Icon icon="terminal-window" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="cap-card-title">Cloud &amp; Engineering</h3>
						<ul class="cap-tags">
							<li>Linux</li>
							<li>Docker</li>
							<li>AWS</li>
							<li>GitHub Actions</li>
							<li>FastAPI</li>
						</ul>
					</li>

					<li class="cap-card">
						<div class="cap-icon" aria-hidden="true">
							<Icon icon="atom" color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="cap-card-title">Research</h3>
						<ul class="cap-tags">
							<li>Quantum Computing</li>
							<li>Scientific Computing</li>
							<li>Simulation</li>
							<li>Optimization Theory</li>
						</ul>
					</li>
				</ol>
			</section>
			<Timeline />
		</main>

		<ContactCTA />
	</div>
</BaseLayout>


<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	/* -------- About Hero (redesigned) -------- */

	.about-hero {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: center;
		padding: 2.5rem 1.25rem 3rem;
		border-radius: 1.5rem;
		overflow: hidden;
		isolation: isolate;
	}

	.about-hero-bg {
		position: absolute;
		inset: 0;
		z-index: -2;
		border-radius: inherit;
		overflow: hidden;
	}

	.about-hero-gradient {
		position: absolute;
		inset: -20%;
		background:
			radial-gradient(circle at 15% 20%, hsla(187, 85%, 53%, 0.28), transparent 55%),
			radial-gradient(circle at 85% 15%, hsla(265, 80%, 60%, 0.22), transparent 60%),
			radial-gradient(circle at 60% 90%, hsla(210, 85%, 55%, 0.24), transparent 55%),
			linear-gradient(180deg, hsla(var(--gray-999-basis), 0.35), hsla(var(--gray-999-basis), 0.15));
		filter: blur(0.5px);
		animation: about-hero-drift 24s ease-in-out infinite alternate;
	}

	.about-hero-noise {
		position: absolute;
		inset: 0;
		background: url('/assets/backgrounds/noise.png') top center/220px repeat;
		mix-blend-mode: overlay;
		opacity: 0.35;
		pointer-events: none;
	}

	@keyframes about-hero-drift {
		0%   { transform: translate3d(0, 0, 0) scale(1); }
		50%  { transform: translate3d(-1.5%, 1%, 0) scale(1.03); }
		100% { transform: translate3d(1.5%, -1%, 0) scale(1.02); }
	}

	.about-hero-accents {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: -1;
		overflow: hidden;
	}

	.about-hero-accents .accent {
		position: absolute;
		font-family: var(--font-brand);
		color: hsla(187, 85%, 75%, 0.28);
		text-shadow: 0 0 12px hsla(187, 85%, 60%, 0.18);
		user-select: none;
		will-change: transform;
		animation: accent-float 14s ease-in-out infinite;
	}

	.accent-1 { top: 8%;  left: 6%;  font-size: 2.4rem; animation-delay: -0.5s; }
	.accent-2 { top: 22%; left: 88%; font-size: 2rem;   animation-delay: -3s;   color: hsla(265, 80%, 78%, 0.28); }
	.accent-3 { top: 58%; left: 4%;  font-size: 2.2rem; animation-delay: -6s;   color: hsla(210, 85%, 78%, 0.28); }
	.accent-4 { top: 78%; left: 82%; font-size: 1.8rem; animation-delay: -1.5s; }
	.accent-5 { top: 46%; left: 92%; font-size: 1.6rem; animation-delay: -8s;   color: hsla(265, 80%, 78%, 0.32); letter-spacing: 0.05em; }
	.accent-6 { top: 88%; left: 20%; font-size: 1.9rem; animation-delay: -4s;   color: hsla(210, 85%, 78%, 0.28); }
	.accent-7 { top: 6%;  left: 62%; font-size: 2.1rem; animation-delay: -2s; }
	.accent-8 { top: 68%; left: 56%; font-size: 1.5rem; animation-delay: -10s;  color: hsla(187, 85%, 78%, 0.30); letter-spacing: 0.05em; }

	@keyframes accent-float {
		0%, 100% { transform: translate3d(0, 0, 0); opacity: 0.75; }
		50%      { transform: translate3d(0, -8px, 0); opacity: 1; }
	}

	.about-hero-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		width: 100%;
	}

	.about-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.about-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
		line-height: 1.12;
		color: var(--gray-0);
		font-weight: 600;
		max-width: 22ch;
	}

	.about-lede {
		margin: 0;
		max-width: 62ch;
		color: var(--gray-200);
		font-size: var(--text-md);
		line-height: 1.7;
	}

	.about-hero-portrait {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 22rem;
	}

	.about-hero-portrait img {
		width: 100%;
		height: auto;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		border: 1px solid hsla(210, 80%, 70%, 0.14);
	}

	@media (min-width: 50em) {
		.about-hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			gap: 3.75rem;
			padding: 4rem 3rem;
			align-items: center;
		}

		.about-hero-content {
			gap: 1.5rem;
		}

		.about-lede {
			font-size: var(--text-lg);
		}

		.about-hero-portrait {
			max-width: none;
			justify-self: end;
		}

		.about-hero-portrait img {
			aspect-ratio: 3 / 4;
			border-radius: 2.5rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.about-hero-gradient,
		.about-hero-accents .accent {
			animation: none;
		}
	}

	/* -------- My Story (storytelling section) -------- */

	.my-story {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		padding: 2.5rem 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.25)
		);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
	}

	.my-story::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(
			circle at 90% -10%,
			hsla(187, 85%, 53%, 0.14),
			transparent 55%
		);
	}

	.story-header {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.story-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.story-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-2xl), 3.6vw, var(--text-4xl));
		line-height: 1.15;
		color: var(--gray-0);
		font-weight: 600;
	}

	.story-divider {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.story-divider-line {
		flex: 1;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			hsla(187, 85%, 60%, 0.35),
			transparent
		);
	}

	.story-divider-dot {
		width: 6px;
		height: 6px;
		border-radius: 999rem;
		background: var(--accent-regular);
		box-shadow: 0 0 12px hsla(187, 85%, 60%, 0.65);
	}

	.story-body {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		color: var(--gray-200);
		font-size: var(--text-md);
		line-height: 1.75;
	}

	.story-body p {
		margin: 0;
	}

	.story-chapters {
		position: relative;
		list-style: none;
		margin: 0.5rem 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
	}

	.chapter {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.55rem 0.9rem;
		border: 1px solid hsla(210, 80%, 70%, 0.18);
		border-radius: 999rem;
		background: hsla(var(--gray-999-basis), 0.35);
		color: var(--gray-100);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		letter-spacing: 0.04em;
	}

	.chapter-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.85rem;
		height: 1.85rem;
		border-radius: 0.6rem;
		background: hsla(187, 85%, 53%, 0.10);
		border: 1px solid hsla(187, 85%, 53%, 0.22);
	}

	.chapter-arrow {
		color: var(--gray-400);
		font-size: var(--text-md);
		user-select: none;
	}

	@media (min-width: 50em) {
		.my-story {
			padding: 3.25rem 3rem;
			gap: 2rem;
		}

		.story-body {
			font-size: var(--text-lg);
		}
	}

	/* -------- How I Think (principles grid) -------- */

	.how-i-think {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.think-header {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.think-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.think-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-2xl), 3.6vw, var(--text-4xl));
		line-height: 1.15;
		color: var(--gray-0);
		font-weight: 600;
	}


	.think-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.15rem;
	}

	@media (min-width: 40em) {
		.think-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 60em) {
		.think-grid {
			grid-template-columns: repeat(6, 1fr);
		}
		.think-card {
			grid-column: span 2;
		}
		.think-card:nth-child(4) {
			grid-column: 2 / span 2;
		}
		.think-card:nth-child(5) {
			grid-column: 4 / span 2;
		}
	}

	.think-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		border-radius: 1.25rem;
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.25)
		);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		cursor: default;
		transition:
			transform var(--theme-transition),
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.think-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 85% -10%,
			hsla(187, 85%, 53%, 0.16),
			transparent 55%
		);
		opacity: 0;
		transition: opacity var(--theme-transition);
		pointer-events: none;
	}

	.think-card:hover,
	.think-card:focus-visible,
	.think-card:focus-within {
		transform: translateY(-3px);
		border-color: hsla(187, 85%, 53%, 0.42);
		box-shadow:
			var(--shadow-md),
			0 0 24px -8px hsla(187, 85%, 53%, 0.45);
		outline: none;
	}

	.think-card:hover::before,
	.think-card:focus-visible::before,
	.think-card:focus-within::before {
		opacity: 1;
	}

	.think-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.75rem;
		background: hsla(187, 85%, 53%, 0.10);
		border: 1px solid hsla(187, 85%, 53%, 0.22);
	}

	.think-card-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.think-card-desc {
