		.xp-hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			grid-template-areas:
				'content illustration'
				'scroll  scroll';
			column-gap: 4rem;
			row-gap: 2.5rem;
			padding: 5rem 3.5rem 3.5rem;
			align-items: center;
			min-height: 38rem;
		}

		.xp-hero-content       { grid-area: content;      gap: 1.75rem; }
		.xp-hero-illustration  { grid-area: illustration; justify-self: end; max-width: none; }
		.xp-scroll             { grid-area: scroll; justify-self: center; margin-top: 1.5rem; font-size: var(--text-base); }

		.xp-lede { font-size: var(--text-lg); }

		.xp-cta {
			flex-direction: row;
			align-items: center;
			gap: 1.25rem;
			margin-top: 1rem;
		}

		.xp-cta-secondary {
			padding: 1.125rem 2.5rem;
			font-size: var(--text-xl);
		}
	}

	@media (min-width: 72em) {
		.xp-title {
			font-size: clamp(3.25rem, 5.6vw, 5.25rem);
		}
	}

	/* --- Accessibility: reduced motion --- */

	@media (prefers-reduced-motion: reduce) {
		.xp-hero-gradient,
		.xp-curve,
		.xp-particle,
		.xp-ill-quantum,
		.xp-node,
		.xp-scroll-arrow,
		.xp-hero-illustration {
			animation: none !important;
		}
		.xp-eyebrow,
		.xp-line,
		.xp-lede,
		.xp-cta-primary,
		.xp-cta-secondary,
		.xp-hero-illustration,
		.xp-scroll {
			opacity: 1 !important;
			transform: none !important;
		}
	}

	/* =====================================================================
	   CURRENT FOCUS — engineering mission section
	   ===================================================================== */

	.cf {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	/* --- Intro row (55 / 45) --- */

	.cf-intro {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		align-items: stretch;
	}

	.cf-copy {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.cf-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.cf-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-2xl), 4.2vw, var(--text-4xl));
		line-height: 1.1;
		letter-spacing: -0.01em;
		color: var(--gray-0);
		font-weight: 600;
	}

	.cf-lede {
		margin: 0;
		max-width: 62ch;
		color: var(--gray-200);
		font-size: var(--text-md);
		line-height: 1.7;
	}

	/* --- Illustration (right column) --- */

	.cf-illustration {
		position: relative;
		width: 100%;
		max-width: 32rem;
		align-self: center;
		border-radius: 1.5rem;
		padding: 0.5rem;
		border: 1px solid hsla(187, 85%, 60%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.25)
		);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
	}


	.cf-illustration::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(
			circle at 85% -10%,
			hsla(187, 85%, 53%, 0.14),
			transparent 55%
		);
	}

	.cf-illustration svg {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 1.15rem;
		animation: cf-float 14s ease-in-out infinite;
		will-change: transform;
	}

	@keyframes cf-float {
		0%, 100% { transform: translate3d(0, 0, 0); }
		50%      { transform: translate3d(0, -6px, 0); }
	}

	.cf-orbit-inner {
		transform-origin: center;
		transform-box: fill-box;
		animation: cf-orbit-rotate 110s linear infinite;
	}

	@keyframes cf-orbit-rotate {
		to { transform: rotate(360deg); }
	}

	.cf-dot {
		animation: cf-dot-pulse 5s ease-in-out infinite;
		transform-origin: center;
		transform-box: fill-box;
	}
	.cf-nodes g:nth-child(1) .cf-dot { animation-delay: -0.4s; }
	.cf-nodes g:nth-child(2) .cf-dot { animation-delay: -1.2s; }
	.cf-nodes g:nth-child(3) .cf-dot { animation-delay: -2.0s; }
	.cf-nodes g:nth-child(4) .cf-dot { animation-delay: -2.8s; }
	.cf-nodes g:nth-child(5) .cf-dot { animation-delay: -3.6s; }
	.cf-dot-hero {
		filter: drop-shadow(0 0 6px rgba(34,211,238,0.75));
	}

	@keyframes cf-dot-pulse {
		0%, 100% { transform: scale(1);    opacity: 0.85; }
		50%      { transform: scale(1.35); opacity: 1;    }
	}

	.cf-label {
		font-family: var(--font-brand);
		font-size: 11px;
		fill: var(--gray-200);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.cf-label-strong { fill: var(--gray-0); }

	.cf-curve {
		stroke-dasharray: 5 7;
		animation: cf-curve-flow 24s linear infinite;
	}

	@keyframes cf-curve-flow {
		to { stroke-dashoffset: -240; }
	}

	/* --- Cards --- */

	.cf-cards {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.15rem;
	}

	.cf-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		padding: 1.5rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		border-radius: 1.25rem;
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.6),
			hsla(var(--gray-999-basis), 0.28)
		);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		cursor: default;
		opacity: 0;
		transform: translateY(14px);
		animation: cf-card-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
		animation-delay: var(--cf-delay, 0s);
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			border-color 0.35s ease,
			box-shadow 0.35s ease;
	}

	@keyframes cf-card-in {
		to { opacity: 1; transform: translateY(0); }
	}

	/* Inner glow overlay */
	.cf-card::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(
			circle at 85% -10%,
			hsla(187, 85%, 53%, 0.18),
			transparent 55%
		);
		opacity: 0;
		transition: opacity 0.35s ease;
	}

	/* Animated gradient border on hover */
	.cf-card::after {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		padding: 1px;
		background: linear-gradient(
			130deg,
			hsla(187, 85%, 60%, 0.6),
			hsla(265, 80%, 65%, 0.6),
			hsla(187, 85%, 60%, 0.6)
		);
		background-size: 220% 220%;
		-webkit-mask:
			linear-gradient(#000 0 0) content-box,
			linear-gradient(#000 0 0);
		-webkit-mask-composite: xor;
				mask-composite: exclude;
		opacity: 0;
		transition: opacity 0.35s ease;
		animation: cf-border-shimmer 6s linear infinite;
		pointer-events: none;
	}

	@keyframes cf-border-shimmer {
		from { background-position: 0 50%; }
		to   { background-position: 220% 50%; }
	}

	.cf-card:hover,
	.cf-card:focus-visible,
	.cf-card:focus-within {
		transform: translateY(-4px);
		border-color: hsla(187, 85%, 60%, 0.35);
		box-shadow:
			var(--shadow-md),
			0 0 30px -10px hsla(187, 85%, 60%, 0.55),
			0 0 40px -18px hsla(265, 80%, 65%, 0.45);
		outline: none;
	}

	.cf-card:hover::before,
	.cf-card:focus-visible::before,
	.cf-card:focus-within::before,
	.cf-card:hover::after,
	.cf-card:focus-visible::after,
	.cf-card:focus-within::after {
		opacity: 1;
	}

	.cf-card-head {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.cf-card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 0.7rem;
		background: hsla(187, 85%, 53%, 0.10);
		border: 1px solid hsla(187, 85%, 53%, 0.22);
		flex-shrink: 0;
	}

	.cf-card-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.cf-card-desc {
		margin: 0;
		color: var(--gray-100);
		font-size: 0.98rem;
		line-height: 1.6;
		/* Primary content of the card */
		flex: 1 1 auto;
	}

	.cf-tags {
		margin: 0;
		padding: 0.75rem 0 0;
		border-top: 1px solid hsla(210, 80%, 70%, 0.10);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0 0.55rem;
		row-gap: 0.25rem;
		font-family: var(--font-brand);
		font-size: 0.74rem;
		letter-spacing: 0.06em;
		color: var(--gray-400);
		margin-top: auto; /* keep tags pinned to bottom for equal-height cards */
	}

	.cf-tags span {
		display: inline-flex;
		align-items: center;
	}

	/* Dot separator between tags */
	.cf-tags span + span::before {
		content: '•';
		margin-right: 0.55rem;
		color: hsla(187, 85%, 60%, 0.55);
	}

	/* --- Responsive breakpoints --- */

	/* Tablet: 2x2 card grid */
	@media (min-width: 40em) {
		.cf-cards {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.25rem;
		}
	}

	/* Desktop: two-column intro (55 / 45) + 4-across cards */
	@media (min-width: 60em) {
		.cf {
			gap: 3rem;
		}

		.cf-intro {
			display: grid;
			grid-template-columns: 55fr 45fr;
			gap: 3.5rem;
			align-items: center;
		}

		.cf-copy { gap: 1.5rem; }
		.cf-lede { font-size: var(--text-lg); }

		.cf-illustration {
			max-width: none;
			justify-self: end;
		}

		.cf-cards {
			grid-template-columns: repeat(4, 1fr);
			gap: 1.25rem;
		}
	}

	/* --- Reduced motion --- */

	@media (prefers-reduced-motion: reduce) {
		.cf-illustration svg,
		.cf-orbit-inner,
		.cf-dot,
		.cf-curve,
		.cf-card,
		.cf-card::after {
			animation: none !important;
		}
		.cf-card {
			opacity: 1 !important;
			transform: none !important;
			transition: none !important;
		}
		.cf-card:hover,
		.cf-card:focus-visible,
		.cf-card:focus-within {
			transform: none !important;
		}
	}

	/* =====================================================================
	   ENGINEERING JOURNEY — alternating timeline
	   ===================================================================== */

	.jr {
		--jr-accent: #22d3ee;
		--jr-accent-soft: hsla(187, 85%, 60%, 0.35);
		--jr-accent-glow: hsla(187, 85%, 60%, 0.6);
		--jr-rail-w: 2px;
		--jr-node-size: 3.75rem;
		--jr-node-inner: 0.75rem;

		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		outline: none;
		scroll-margin-top: 5rem;
	}

	/* Accent variants (each milestone can carry its own hue) */
	.jr-accent-cyan   { --jr-accent: #22d3ee; --jr-accent-soft: hsla(187, 85%, 60%, 0.35); --jr-accent-glow: hsla(187, 85%, 60%, 0.6); }
	.jr-accent-violet { --jr-accent: #a855f7; --jr-accent-soft: hsla(265, 85%, 68%, 0.35); --jr-accent-glow: hsla(265, 85%, 68%, 0.6); }
	.jr-accent-blue   { --jr-accent: #60a5fa; --jr-accent-soft: hsla(217, 90%, 68%, 0.35); --jr-accent-glow: hsla(217, 90%, 68%, 0.6); }
	.jr-accent-teal   { --jr-accent: #5eead4; --jr-accent-soft: hsla(170, 78%, 65%, 0.35); --jr-accent-glow: hsla(170, 78%, 65%, 0.6); }

	/* -- Section header -- */

	.jr-header {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.jr-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.jr-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-2xl), 4.2vw, var(--text-4xl));
		line-height: 1.1;
		letter-spacing: -0.01em;
		color: var(--gray-0);
		font-weight: 600;
	}

	.jr-subtitle {
		margin: 0;
		max-width: 62ch;
		color: var(--gray-200);
		font-size: var(--text-md);
		line-height: 1.65;
	}

	/* -- Jump bar (quick nav across eras) -- */

	.jr-jumpbar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.jr-jump {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.45rem 0.85rem;
		border-radius: 999rem;
		border: 1px solid hsla(210, 80%, 70%, 0.16);
		background: hsla(var(--gray-999-basis), 0.35);
		color: var(--gray-200);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: 0.78rem;
		letter-spacing: 0.06em;
		transition:
			background-color var(--theme-transition),
			border-color var(--theme-transition),
			color var(--theme-transition),
			transform var(--theme-transition);
	}

	.jr-jump-year {
		color: var(--jr-accent);
		font-weight: 600;
	}

	.jr-jump-company {
		color: var(--gray-300);
	}

	.jr-jump:hover,
	.jr-jump:focus-visible,
	.jr-jump.is-active {
		border-color: var(--jr-accent-soft);
		background: hsla(var(--gray-999-basis), 0.55);
		color: var(--gray-0);
		outline: none;
		transform: translateY(-1px);
	}

	.jr-jump:focus-visible {
		box-shadow: 0 0 0 3px var(--jr-accent-soft);
	}

	/* -- Timeline structure -- */

	.jr-timeline {
		list-style: none;
		padding: 0;
		margin: 0;
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.jr-timeline::before {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		left: calc(var(--jr-node-size) / 2);
		width: var(--jr-rail-w);
		background: linear-gradient(
			180deg,
			hsla(187, 85%, 60%, 0.55) 0%,
			hsla(265, 85%, 68%, 0.35) 55%,
			hsla(210, 80%, 70%, 0.12) 100%
		);
		border-radius: 999rem;
		pointer-events: none;
		box-shadow: 0 0 12px hsla(187, 85%, 60%, 0.35);
	}

	.jr-item {
		position: relative;
		display: grid;
		grid-template-columns: var(--jr-node-size) 1fr;
		column-gap: 1.25rem;
		align-items: start;
		opacity: 0;
		transform: translateY(28px);
		z-index: 1;
		transition:
			opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.jr-item.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* When milestones overlap on desktop, whichever the user is engaging with
	   should always rise above its neighbours. */
	.jr-item:hover,
	.jr-item:focus-within,
	.jr-item.is-active {
		z-index: 3;
	}

	/* -- Timeline node (marker) -- */

	.jr-node {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		width: var(--jr-node-size);
		padding-top: 0.5rem;
		text-decoration: none;
		color: var(--gray-200);
		outline: none;
	}

	.jr-node-halo {
		position: absolute;
		top: 0.25rem;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 999rem;
		background: radial-gradient(
			circle,
			var(--jr-accent-glow) 0%,
			transparent 65%
		);
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.jr-node-dot {
		position: relative;
		width: 1.15rem;
		height: 1.15rem;
		border-radius: 999rem;
		background: hsla(224, 72%, 7%, 0.95);
		border: 2px solid var(--jr-accent);
		box-shadow: 0 0 0 4px hsla(var(--gray-999-basis), 0.75);
		transition:
			transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			border-color 0.3s ease,
			box-shadow 0.3s ease,
			background-color 0.3s ease;
	}

	.jr-node-year {
		margin-top: 0.75rem;
		font-family: var(--font-brand);
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--gray-400);
		text-align: center;
		line-height: 1.25;
		transition: color 0.3s ease;
	}

	.jr-item.is-active .jr-node-halo,
	.jr-node:hover .jr-node-halo,
	.jr-node:focus-visible .jr-node-halo {
		opacity: 1;
	}

	.jr-item.is-active .jr-node-dot,
	.jr-node:hover .jr-node-dot,
	.jr-node:focus-visible .jr-node-dot {
		background: var(--jr-accent);
		transform: scale(1.2);
		box-shadow:
			0 0 0 4px hsla(var(--gray-999-basis), 0.75),
			0 0 22px var(--jr-accent-glow);
	}

	.jr-item.is-active .jr-node-year,
	.jr-node:hover .jr-node-year,
	.jr-node:focus-visible .jr-node-year {
		color: var(--gray-0);
	}

	.jr-node:focus-visible {
		outline: none;
	}

	.jr-node:focus-visible .jr-node-dot {
		box-shadow:
			0 0 0 4px hsla(var(--gray-999-basis), 0.75),
			0 0 0 7px var(--jr-accent-soft);
	}

	/* -- Connector line from rail to card -- */

	.jr-connector {
		display: none;
	}

	/* -- Card -- */

	.jr-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.5rem 1.35rem;
		border-radius: 1.15rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.6),
			hsla(var(--gray-999-basis), 0.28)
		);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		outline: none;
		transition:
			transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			border-color 0.4s ease,
			box-shadow 0.4s ease;
	}

	.jr-card::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(
			circle at 90% -10%,
			var(--jr-accent-soft),
			transparent 55%
		);
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.jr-card:hover,
	.jr-card:focus-visible,
	.jr-item.is-active .jr-card {
		transform: translateY(-3px);
		border-color: var(--jr-accent-soft);
		box-shadow:
			var(--shadow-md),
			0 0 28px -12px var(--jr-accent-glow);
	}

	.jr-card:hover::before,
	.jr-card:focus-visible::before,
	.jr-item.is-active .jr-card::before {
		opacity: 0.85;
	}

	/* Card head — position is the primary heading, company & location
	   step down as a subtitle, era sits below as a small accent line. */
	.jr-card-head {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.jr-card-position {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		line-height: 1.18;
		letter-spacing: -0.005em;
		color: var(--gray-0);
