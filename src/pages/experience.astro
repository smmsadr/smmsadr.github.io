---
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// ------------------------------------------------------------------
// Curated engineering journey — story-first, not a chronological CV.
// Order: newest first (most visually emphasized).
// Metrics are qualitative markers drawn from existing role content;
// no numeric metrics are invented.
// ------------------------------------------------------------------
type TechGroup = { label: string; items: string[] };

type Milestone = {
	slug: string;                 // matches src/content/experience/<slug>.md
	company: string;
	position: string;
	location: string;             // e.g. "Kuala Lumpur, Malaysia"
	era: string;                  // display range, e.g. "2021 — Present"
	shortLabel: string;           // for the timeline node
	mission: string;
	achievements: string[];
	tech: TechGroup[];
	metrics: string[];
	emphasis: 'primary' | 'secondary' | 'tertiary';
	accent: 'cyan' | 'violet' | 'blue' | 'teal';
	current?: boolean;
};

const journey: Milestone[] = [
