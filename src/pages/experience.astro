---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('experience')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Experience | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Professional experience in quantitative engineering, data science, and AI systems."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Experience"
				tagline="Roles across quantitative engineering, machine learning, and platform delivery."
				align="start"
			/>
			<Grid variant="offset">
				{
					entries.map((entry) => (
						<li>
							<PortfolioPreview entry={entry} hrefBase="/experience" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

