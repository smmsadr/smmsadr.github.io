<script>
	// Engineering Journey — scroll-triggered reveal + node ↔ card linking.
	(() => {
		const items = Array.from(
			document.querySelectorAll<HTMLLIElement>('.jr-item'),
		);
		if (items.length === 0) return;

		const reduceMotion =
			typeof window !== 'undefined' &&
			window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (reduceMotion) {
			items.forEach((el) => el.classList.add('is-visible'));
		} else if ('IntersectionObserver' in window) {
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							io.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
			);
			items.forEach((el) => io.observe(el));
		} else {
			items.forEach((el) => el.classList.add('is-visible'));
		}

		// Track which milestone is currently on-screen so nodes & jumpbar glow.
		const activeObserver =
			'IntersectionObserver' in window
				? new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								const li = entry.target as HTMLElement;
								const slug = li.dataset.slug;
								if (!slug) return;
								if (entry.isIntersecting) {
									li.classList.add('is-active');
									document
										.querySelectorAll(`.jr-jump[data-jump="${slug}"]`)
										.forEach((n) => n.classList.add('is-active'));
								} else {
									li.classList.remove('is-active');
									document
										.querySelectorAll(`.jr-jump[data-jump="${slug}"]`)
										.forEach((n) => n.classList.remove('is-active'));
								}
							});
						},
						{ threshold: 0.35 },
				  )
				: null;

		if (activeObserver) items.forEach((el) => activeObserver.observe(el));

		// Smooth scroll for node & jumpbar links (respects reduced-motion).
		document
			.querySelectorAll<HTMLAnchorElement>('.jr-node, .jr-jump')
			.forEach((link) => {
				link.addEventListener('click', (event) => {
					const href = link.getAttribute('href') || '';
					if (!href.startsWith('#')) return;
					const target = document.querySelector(href);
					if (!target) return;
					event.preventDefault();
					target.scrollIntoView({
						behavior: reduceMotion ? 'auto' : 'smooth',
						block: 'center',
					});
					// Update URL hash without jumping.
					history.replaceState(null, '', href);
					(target as HTMLElement).focus({ preventScroll: true });
				});
			});
	})();
</script>

