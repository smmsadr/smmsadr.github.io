---

<BaseLayout
	title="Experience | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Engineering systems that create real-world impact — quantitative engineering, optimization, AI, and scalable software."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<section class="xp-hero" aria-labelledby="xp-hero-title">
				<!-- Premium animated background: gradient + blueprint grid + particles + curves -->
				<div class="xp-hero-bg" aria-hidden="true">
					<div class="xp-hero-gradient"></div>
					<div class="xp-hero-grid"></div>
					<svg
						class="xp-hero-curves"
						viewBox="0 0 1440 600"
						preserveAspectRatio="none"
						aria-hidden="true"
					>
						<defs>
							<linearGradient id="xp-curve-a" x1="0" x2="1" y1="0" y2="1">
								<stop offset="0%" stop-color="#67e8f9" stop-opacity="0.55" />
								<stop offset="100%" stop-color="#a855f7" stop-opacity="0" />
							</linearGradient>
							<linearGradient id="xp-curve-b" x1="0" x2="1" y1="1" y2="0">
								<stop offset="0%" stop-color="#22d3ee" stop-opacity="0.35" />
								<stop offset="100%" stop-color="#6d28d9" stop-opacity="0" />
							</linearGradient>
						</defs>
						<path
							class="xp-curve xp-curve-1"
							d="M-40 420 C 220 340, 420 500, 720 380 S 1240 220, 1500 300"
							fill="none"
							stroke="url(#xp-curve-a)"
							stroke-width="1.1"
						/>
						<path
							class="xp-curve xp-curve-2"
							d="M-40 520 C 260 480, 500 340, 780 460 S 1220 560, 1500 440"
							fill="none"
							stroke="url(#xp-curve-b)"
							stroke-width="1.1"
						/>
					</svg>
					<div class="xp-hero-particles">
						<span class="xp-particle" style="--x: 8%;  --y: 18%; --d: 0s;  --s: 3px;"></span>
						<span class="xp-particle" style="--x: 22%; --y: 74%; --d: 3s;  --s: 2px;"></span>
						<span class="xp-particle" style="--x: 38%; --y: 34%; --d: 6s;  --s: 4px;"></span>
						<span class="xp-particle" style="--x: 52%; --y: 82%; --d: 1.5s;--s: 2px;"></span>
						<span class="xp-particle" style="--x: 66%; --y: 12%; --d: 4.5s;--s: 3px;"></span>
						<span class="xp-particle" style="--x: 74%; --y: 58%; --d: 7s;  --s: 2px;"></span>
						<span class="xp-particle" style="--x: 84%; --y: 28%; --d: 2.5s;--s: 3px;"></span>
						<span class="xp-particle" style="--x: 92%; --y: 68%; --d: 5.5s;--s: 2px;"></span>
						<span class="xp-particle" style="--x: 14%; --y: 88%; --d: 8s;  --s: 2px;"></span>
						<span class="xp-particle" style="--x: 46%; --y: 6%;  --d: 6.5s;--s: 3px;"></span>
					</div>
				</div>

				<!-- Left column: text -->
				<div class="xp-hero-content">
					<p class="xp-eyebrow">Experience</p>
					<h1 id="xp-hero-title" class="xp-title">
						<span class="xp-line xp-line-1">Engineering Systems</span>
						<span class="xp-line xp-line-2">That Create</span>
						<span class="xp-line xp-line-3">
							<span class="xp-gradient-text">Real-World Impact</span>
						</span>
					</h1>
					<p class="xp-lede">
						Every project is an opportunity to transform complex data into reliable
						decisions. My work combines quantitative engineering, optimization,
						artificial intelligence, and scalable software systems to solve practical
						challenges across industries.
					</p>
					<div class="xp-cta">
						<div class="xp-cta-primary">
							<CallToAction href="#signature-systems">
								Explore Signature Systems
								<Icon icon="arrow-right" size="1.2em" />
							</CallToAction>
						</div>
						<a href="/Mahdi-CV.pdf" download class="xp-cta-secondary">
							Download CV
							<Icon icon="download" size="1.2em" />
						</a>
					</div>
				</div>

				<!-- Right column: abstract engineering illustration -->
				<div class="xp-hero-illustration" aria-hidden="true">
					<svg viewBox="0 0 480 560" role="img" aria-label="Abstract engineering systems illustration">
						<defs>
							<linearGradient id="xp-ill-stroke" x1="0" x2="1" y1="0" y2="1">
								<stop offset="0%" stop-color="#67e8f9" stop-opacity="0.9" />
								<stop offset="60%" stop-color="#22d3ee" stop-opacity="0.7" />
								<stop offset="100%" stop-color="#a855f7" stop-opacity="0.9" />
							</linearGradient>
							<linearGradient id="xp-ill-opt" x1="0" x2="1" y1="1" y2="0">
								<stop offset="0%" stop-color="#22d3ee" stop-opacity="0.95" />
								<stop offset="100%" stop-color="#a855f7" stop-opacity="0.6" />
							</linearGradient>
							<radialGradient id="xp-ill-glow" cx="50%" cy="50%" r="50%">
								<stop offset="0%" stop-color="#22d3ee" stop-opacity="0.35" />
								<stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
							</radialGradient>
							<pattern id="xp-blueprint" width="32" height="32" patternUnits="userSpaceOnUse">
								<path
									d="M 32 0 L 0 0 0 32"
									fill="none"
									stroke="rgba(103,232,249,0.08)"
									stroke-width="0.6"
								/>
							</pattern>
						</defs>

						<!-- Blueprint grid & soft glow backdrop -->
						<rect x="0" y="0" width="480" height="560" fill="url(#xp-blueprint)" opacity="0.9" />
						<circle cx="240" cy="290" r="220" fill="url(#xp-ill-glow)" />

						<!-- Quantum-inspired concentric rings (slow rotate) -->
						<g transform="translate(240 290)">
							<g class="xp-ill-quantum">
								<ellipse cx="0" cy="0" rx="180" ry="70" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.8" />
								<ellipse cx="0" cy="0" rx="180" ry="70" transform="rotate(60)" fill="none" stroke="rgba(103,232,249,0.35)" stroke-width="0.8" />
								<ellipse cx="0" cy="0" rx="180" ry="70" transform="rotate(-60)" fill="none" stroke="rgba(34,211,238,0.30)" stroke-width="0.8" />
								<circle cx="0" cy="0" r="6" fill="#67e8f9" opacity="0.9" />
							</g>
						</g>

						<!-- Optimization / convergence curve -->
						<g class="xp-ill-optcurve">
							<path
								d="M 40 460 C 120 460, 160 380, 210 320 S 320 180, 440 130"
								fill="none"
								stroke="url(#xp-ill-opt)"
								stroke-width="2.2"
								stroke-linecap="round"
							/>
							<!-- Iteration ticks -->
							<circle cx="70"  cy="452" r="3" fill="#67e8f9" opacity="0.6" />
							<circle cx="130" cy="418" r="3" fill="#67e8f9" opacity="0.7" />
							<circle cx="185" cy="355" r="3" fill="#22d3ee" opacity="0.85" />
							<circle cx="250" cy="280" r="3.2" fill="#22d3ee" />
							<circle cx="330" cy="205" r="3.5" fill="#a855f7" />
							<circle cx="420" cy="140" r="4" fill="#a855f7" />
							<!-- Axes (blueprint) -->
							<line x1="30" y1="470" x2="450" y2="470" stroke="rgba(147,197,253,0.20)" stroke-width="0.8" />
							<line x1="30" y1="470" x2="30" y2="110" stroke="rgba(147,197,253,0.20)" stroke-width="0.8" />
						</g>

						<!-- Connected network nodes -->
						<g class="xp-ill-network">
							<line x1="120" y1="140" x2="220" y2="90"  stroke="rgba(103,232,249,0.45)" stroke-width="0.9" />
							<line x1="220" y1="90"  x2="340" y2="140" stroke="rgba(103,232,249,0.45)" stroke-width="0.9" />
							<line x1="120" y1="140" x2="180" y2="240" stroke="rgba(168,85,247,0.40)"  stroke-width="0.9" />
							<line x1="340" y1="140" x2="300" y2="240" stroke="rgba(168,85,247,0.40)"  stroke-width="0.9" />
							<line x1="180" y1="240" x2="300" y2="240" stroke="rgba(34,211,238,0.55)"  stroke-width="0.9" />
							<line x1="220" y1="90"  x2="180" y2="240" stroke="rgba(103,232,249,0.30)" stroke-width="0.9" />
							<line x1="220" y1="90"  x2="300" y2="240" stroke="rgba(103,232,249,0.30)" stroke-width="0.9" />

							<circle class="xp-node" cx="120" cy="140" r="5" />
							<circle class="xp-node" cx="220" cy="90"  r="6" />
							<circle class="xp-node" cx="340" cy="140" r="5" />
							<circle class="xp-node" cx="180" cy="240" r="5" />
							<circle class="xp-node" cx="300" cy="240" r="5" />
						</g>

						<!-- Flowing data path with pulses -->
						<g class="xp-ill-flow">
							<path
								id="xp-flow-path"
								d="M 40 500 C 140 500, 200 460, 250 420 C 320 370, 380 380, 460 330"
								fill="none"
								stroke="url(#xp-ill-stroke)"
								stroke-width="1.3"
								stroke-dasharray="4 6"
								opacity="0.75"
							/>
							<circle r="3.2" fill="#67e8f9">
								<animateMotion dur="14s" repeatCount="indefinite" rotate="auto">
									<mpath href="#xp-flow-path" />
								</animateMotion>
							</circle>
							<circle r="2.4" fill="#a855f7">
								<animateMotion dur="14s" begin="-7s" repeatCount="indefinite" rotate="auto">
									<mpath href="#xp-flow-path" />
								</animateMotion>
							</circle>
						</g>

						<!-- Corner blueprint marks -->
						<g stroke="rgba(103,232,249,0.35)" stroke-width="0.8" fill="none">
							<path d="M 12 24 L 12 12 L 24 12" />
							<path d="M 468 24 L 468 12 L 456 12" />
							<path d="M 12 536 L 12 548 L 24 548" />
							<path d="M 468 536 L 468 548 L 456 548" />
						</g>
					</svg>
				</div>

				<!-- Scroll indicator -->
				<a class="xp-scroll" href="#signature-systems" aria-label="Scroll to explore the systems I've built">
					<span class="xp-scroll-arrow" aria-hidden="true">↓</span>
					<span class="xp-scroll-label">Scroll to explore the systems I've built</span>
				</a>
			</section>

			<!-- ============================================================
			     CURRENT FOCUS — engineering mission, not employment
			     ============================================================ -->
			<section class="cf" aria-labelledby="cf-title">
				<div class="cf-intro">
					<div class="cf-copy">
						<p class="cf-eyebrow">Current Focus</p>
						<h2 id="cf-title" class="cf-title">
							Engineering Intelligent<br />Decision Systems
						</h2>
						<p class="cf-lede">
							I engineer intelligent decision systems that transform complex data
							into reliable, explainable, and actionable decisions. My work
							combines quantitative modelling, optimization, machine learning,
							and modern software engineering into scalable production platforms.
						</p>
						<p class="cf-lede">
							Rather than solving isolated problems, I design reusable systems
							that evolve over time—from optimization engines and AI-assisted
							workflows to simulation platforms and decision intelligence tools.
						</p>
					</div>

					<div class="cf-illustration" aria-hidden="true">
						<svg viewBox="0 0 440 460" role="img" aria-label="Interconnected decision systems diagram">
							<defs>
								<linearGradient id="cf-stroke" x1="0" y1="0" x2="1" y2="1">
									<stop offset="0%"   stop-color="#67e8f9" stop-opacity="0.95" />
									<stop offset="60%"  stop-color="#22d3ee" stop-opacity="0.75" />
									<stop offset="100%" stop-color="#a855f7" stop-opacity="0.95" />
								</linearGradient>
								<linearGradient id="cf-edge" x1="0" y1="0" x2="1" y2="0">
									<stop offset="0%"   stop-color="#22d3ee" stop-opacity="0.75" />
									<stop offset="100%" stop-color="#a855f7" stop-opacity="0.75" />
								</linearGradient>
								<radialGradient id="cf-glow" cx="50%" cy="50%" r="50%">
									<stop offset="0%"   stop-color="#22d3ee" stop-opacity="0.28" />
									<stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
								</radialGradient>
								<pattern id="cf-grid" width="28" height="28" patternUnits="userSpaceOnUse">
									<path d="M 28 0 L 0 0 0 28" fill="none" stroke="rgba(103,232,249,0.07)" stroke-width="0.6" />
								</pattern>
							</defs>

							<!-- Blueprint grid & central glow -->
							<rect width="440" height="460" fill="url(#cf-grid)" />
							<circle cx="220" cy="230" r="180" fill="url(#cf-glow)" />

							<!-- Subtle quantum-inspired orbit -->
							<g class="cf-orbit" transform="translate(220 230)">
								<g class="cf-orbit-inner">
									<ellipse rx="170" ry="90" fill="none" stroke="rgba(168,85,247,0.22)" stroke-width="0.8" />
									<ellipse rx="170" ry="90" transform="rotate(55)" fill="none" stroke="rgba(103,232,249,0.20)" stroke-width="0.8" />
								</g>
							</g>

							<!-- Mathematical curve (optimization convergence) -->
							<path
								class="cf-curve"
								d="M 40 400 C 110 400, 150 340, 190 300 S 300 200, 400 150"
								fill="none"
								stroke="url(#cf-stroke)"
								stroke-width="1.6"
								stroke-linecap="round"
								opacity="0.55"
							/>

							<!-- Edges (data pipelines / agent workflows) -->
							<g class="cf-edges" stroke="url(#cf-edge)" stroke-width="1.1" fill="none" opacity="0.7">
								<!-- Data → Optimization -->
								<path d="M 70 130 L 200 180" />
								<!-- Data → AI Agent -->
								<path d="M 70 130 L 200 90" />
								<!-- AI Agent → Optimization -->
								<path d="M 200 90 L 200 180" />
								<!-- Optimization → Decision -->
								<path d="M 200 180 L 350 230" />
								<!-- AI Agent → Decision -->
								<path d="M 200 90 L 350 230" />
								<!-- Simulation → Decision -->
								<path d="M 110 320 L 350 230" />
								<!-- Optimization → Simulation (feedback loop) -->
								<path d="M 200 180 L 110 320" stroke-dasharray="4 5" />
								<!-- Decision → AI Agent (feedback) -->
								<path d="M 350 230 L 200 90" stroke-dasharray="4 5" opacity="0.5" />
							</g>

							<!-- Flowing pulses along a data pipeline -->
							<path id="cf-flow-path"
								d="M 70 130 C 140 160, 170 170, 200 180 C 260 200, 300 210, 350 230"
								fill="none" stroke="rgba(103,232,249,0.35)" stroke-width="0.8"
								stroke-dasharray="3 6" />
							<circle r="3" fill="#67e8f9">
								<animateMotion dur="9s" repeatCount="indefinite">
									<mpath href="#cf-flow-path" />
								</animateMotion>
							</circle>
							<circle r="2.4" fill="#a855f7">
								<animateMotion dur="9s" begin="-4.5s" repeatCount="indefinite">
									<mpath href="#cf-flow-path" />
								</animateMotion>
							</circle>

							<!-- Nodes -->
							<g class="cf-nodes">
								<!-- Data source -->
								<g transform="translate(70 130)">
									<circle r="22" fill="hsla(224,72%,7%,0.85)" stroke="rgba(103,232,249,0.65)" stroke-width="1.2" />
									<circle r="4" fill="#67e8f9" class="cf-dot" />
									<text y="42" text-anchor="middle" class="cf-label">Data</text>
								</g>
								<!-- AI Agent -->
								<g transform="translate(200 90)">
									<circle r="26" fill="hsla(224,72%,7%,0.85)" stroke="rgba(168,85,247,0.7)"  stroke-width="1.2" />
									<circle r="4.5" fill="#a855f7" class="cf-dot" />
									<text y="46" text-anchor="middle" class="cf-label">AI Agent</text>
								</g>
