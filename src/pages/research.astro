---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// For now, research pulls from publications collection
// Can be extended with a dedicated research collection later
const research = (await getCollection('publications'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
	title="Research | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Research in quantum computing, AI, and computational science."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Research"
				tagline="Publications, preprints, and research projects in quantum computing, machine learning, and computational science."
				align="start"
			/>
			<Grid variant="offset">
				{
					research.length > 0 ? (
						research.map((entry) => (
							<li>
								<PortfolioPreview entry={entry} hrefBase="/research" />
							</li>
						))
					) : (
						<p>Research content coming soon.</p>
					)
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

