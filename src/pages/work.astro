---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Writing | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Physics, computer science, and philosophy of science writing by Sayed Mohammad Mahdi Sadrnezhaad."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Writing"
				tagline="Selected articles, research notes, and course essays migrated from the older website."
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
