---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('certifications')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Awards & Certificates | Sayed Mohammad Mahdi Sadrnezhaad"
	description="Professional certifications, awards, and recognitions in AI, cloud technologies, and quantum computing."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Awards & Certificates"
				tagline="Professional certifications and awards across AI, quantum computing, data science, and cloud technologies."
				align="start"
			/>
			<Grid variant="offset">
				{
					entries.map((entry) => (
						<li>
							<PortfolioPreview entry={entry} hrefBase="/awards" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

