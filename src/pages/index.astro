---
import { getCollection } from 'astro:content';
// Component Imports
import CallToAction from '../components/CallToAction.astro';
// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Skills from '../components/Skills.astro';
import WhatIExplore from '../components/WhatIExplore.astro';
import WhyDeepSystems from '../components/WhyDeepSystems.astro';
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Content Fetching: latest entries for section previews
const writing = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<div class="hero-content">
					<Hero
						title="Exploring Deep Systems"
						tagline="I design computational systems that transform uncertainty into actionable decisions through quantitative modeling, optimization, Hybrid & Agentic AI, and Quantum Computing."
						align="start"
					>
						<div class="cta-buttons">
							<CallToAction href="/projects/">
								Explore Projects
								<Icon icon="arrow-right" size="1.2em" />
							</CallToAction>
							<a href="/Mahdi-CV.pdf" download class="cta-secondary">
								Download CV
								<Icon icon="download" size="1.2em" />
							</a>
						</div>
						<a class="scroll-indicator" href="#why-deep-title" aria-label="Scroll to explore">
							<span>Scroll to explore</span>
							<span class="scroll-arrow" aria-hidden="true">↓</span>
						</a>
					</Hero>
				</div>

				<img
					alt="Mahdi Sadrnezhaad"
					width="480"
					height="620"
					src="/assets/Mahdi-Profile.png"
				/>
			</header>

			<Skills />
			<WhyDeepSystems />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">


			<WhatIExplore />

			<section class="section with-background with-cta blog-section">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>From the Blog</h3>
					<p>
						Essays, notes, and research summaries — thinking in public, distinct from
						shipped project work.
					</p>
				</header>

				<ol class="blog-list">
					{
						writing.map((entry) => {
							const isExternal = Boolean(entry.data.externalUrl);
							const href = isExternal ? entry.data.externalUrl : `/blog/${entry.id}/`;
							return (
								<li class="blog-item">
									<a
										href={href}
										class="blog-link"
										{...(isExternal
											? { target: '_blank', rel: 'noopener noreferrer' }
											: {})}
									>
										<time class="blog-date" datetime={entry.data.publishDate.toISOString()}>
											{entry.data.publishDate.toLocaleDateString('en-US', {
												year: 'numeric',
												month: 'short',
												day: 'numeric',
											})}
										</time>
										<span class="blog-title">
											{entry.data.title}
											{isExternal && (
												<span class="blog-external" aria-label="External post">
													↗
												</span>
											)}
										</span>
										<span class="blog-excerpt">{entry.data.description}</span>
									</a>
								</li>
							);
						})
					}
				</ol>

				<div class="cta">
					<CallToAction href="/blog/">
						Read the blog
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero :global(.title) {
		max-width: none;
		white-space: normal;
		font-size: var(--text-5xl);
		line-height: 1.1;
		margin-bottom: 1.25rem;
	}

	.hero :global(.tagline) {
		max-width: 50ch;
		font-size: var(--text-lg);
		color: var(--gray-300);
		line-height: 1.55;
		margin-bottom: 2.75rem;
	}

	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.hero-content {
		width: 100%;
	}

	.cta-buttons {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.cta-secondary {
		position: relative;
		display: flex;
		place-content: center;
		text-align: center;
		padding: 0.56em 2em;
		gap: 0.8em;
		color: var(--gray-200);
		text-decoration: none;
		line-height: 1.1;
		border-radius: 999rem;
		overflow: hidden;
		border: 1px solid var(--gray-800);
		background: transparent;
		box-shadow: none;
		white-space: nowrap;
		transition: all var(--theme-transition);
	}

	.cta-secondary:hover,
	.cta-secondary:focus {
		background-color: var(--gray-800);
		border-color: var(--gray-700);
		color: var(--gray-0);
	}

	@media (min-width: 20em) {
		.cta-secondary {
			font-size: var(--text-lg);
		}
	}

	.scroll-indicator {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		margin-top: 2.75rem;
		padding: 0.4rem 0.15rem;
		color: var(--gray-400);
		font-size: var(--text-sm);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		text-decoration: none;
		width: max-content;
		opacity: 0.85;
		transition: color var(--theme-transition), opacity var(--theme-transition);
	}

	.scroll-indicator:hover,
	.scroll-indicator:focus-visible {
		color: var(--gray-100);
		opacity: 1;
	}

	.scroll-arrow {
		display: inline-block;
		animation: scroll-hint 2.4s ease-in-out infinite;
	}

	@keyframes scroll-hint {
		0%, 100% { transform: translateY(0); opacity: 0.7; }
		50%      { transform: translateY(4px); opacity: 1; }
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-arrow { animation: none; }
	}

	@media (min-width: 50em) {
		.cta-buttons {
			flex-direction: row;
			gap: 1.5rem;
		}

		.cta-secondary {
			padding: 1.125rem 2.5rem;
			font-size: var(--text-xl);
		}

		.scroll-indicator {
			margin-top: 3.5rem;
			font-size: var(--text-base);
		}
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.hero-content {
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	/* ====================================================== */
	/* Blog list — editorial rows, intentionally different from portfolio cards */

	.blog-section .blog-list {
		list-style: none;
		padding: 0;
		margin: 0;
		grid-area: gallery;
		display: flex;
		flex-direction: column;
		gap: 0;
		border-top: 1px solid var(--gray-800);
	}

	.blog-item {
		border-bottom: 1px solid var(--gray-800);
	}

	.blog-link {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.35rem;
		padding: 1.15rem 0.25rem;
		text-decoration: none;
		color: var(--gray-200);
		transition:
			color var(--theme-transition),
			background-color var(--theme-transition);
	}

	.blog-link:hover,
	.blog-link:focus-visible {
		color: var(--gray-0);
		background: linear-gradient(
			90deg,
			hsla(var(--gray-999-basis), 0),
			hsla(var(--gray-999-basis), 0.35),
			hsla(var(--gray-999-basis), 0)
		);
	}

	.blog-date {
		font-size: var(--text-sm);
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.blog-title {
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		line-height: 1.25;
		color: var(--gray-100);
	}

	.blog-external {
		display: inline-block;
		margin-inline-start: 0.35em;
		font-size: 0.75em;
		color: var(--accent-regular);
	}

	.blog-excerpt {
		color: var(--gray-300);
		font-size: var(--text-base);
		line-height: 1.55;
	}

	@media (min-width: 50em) {
		.blog-link {
			grid-template-columns: 10rem 1fr;
			column-gap: 2rem;
			row-gap: 0.35rem;
			padding: 1.5rem 0.5rem;
			align-items: baseline;
		}

		.blog-date {
			grid-row: span 2;
			align-self: start;
		}

		.blog-title {
			font-size: var(--text-xl);
		}
	}

</style>
