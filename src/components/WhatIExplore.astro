---
// WhatIExplore.astro
// Five themes that shape the work — glassmorphism cards on a
// faintly animated connection field. Continuation of the
// "Exploring Deep Systems" visual language.

import Icon from './Icon.astro';
import type { iconPaths } from './IconPaths';

type IconKey = keyof typeof iconPaths;

interface Theme {
	icon: IconKey;
	title: string;
	description: string;
	tags: string[];
}

const themes: Theme[] = [
	{
		icon: 'chart-line-up',
		title: 'Quantitative Decision Systems',
		description:
			'Transforming uncertainty into measurable decisions through optimization and mathematical modeling.',
		tags: ['Optimization', 'Forecasting', 'Planning', 'Risk'],
	},
	{
		icon: 'cpu',
		title: 'Hybrid & Agentic AI',
		description:
			'Combining machine learning, reasoning, and autonomous agents to solve complex real-world problems.',
		tags: ['ML', 'LLM Agents', 'Reasoning', 'RL'],
	},
	{
		icon: 'code',
		title: 'Scientific Computing',
		description:
			'Building numerical simulations and computational models that bridge mathematics, engineering, and software.',
		tags: ['Simulation', 'Numerical Methods', 'HPC'],
	},
	{
		icon: 'atom',
		title: 'Quantum Computing',
		description:
			'Investigating hybrid quantum–classical algorithms for optimization and machine learning.',
		tags: ['QML', 'Variational Circuits', 'Simulation'],
	},
	{
		icon: 'strategy',
		title: 'Systems Thinking',
		description:
			'Understanding complexity through feedback, emergence, constraints, and interdisciplinary design.',
		tags: ['Complexity', 'Feedback', 'Design', 'Emergence'],
	},
];
---

<section class="explore" aria-labelledby="explore-title">
	<header class="explore-header">
		<p class="explore-eyebrow">What I Explore</p>
		<h2 id="explore-title" class="explore-title">Five threads that shape the work</h2>
		<p class="explore-intro">
			My work sits at the intersection of mathematics, engineering, artificial intelligence,
			and scientific inquiry. These themes guide the systems I build and the questions I
			continue to explore.
		</p>
	</header>

	<div class="explore-grid-wrapper">
		<!-- Faint animated connection field (decorative) -->
		<svg
			class="explore-connections"
			viewBox="0 0 800 320"
			preserveAspectRatio="none"
			aria-hidden="true"
		>
			<defs>
				<linearGradient id="exploreLineGrad" x1="0" y1="0" x2="1" y2="0">
					<stop offset="0%" stop-color="rgba(56,189,248,0)" />
					<stop offset="50%" stop-color="rgba(125,211,252,0.4)" />
					<stop offset="100%" stop-color="rgba(168,85,247,0)" />
				</linearGradient>
			</defs>
			<path
				class="explore-line"
				d="M20 60 C 180 40, 360 140, 520 90 S 760 180, 780 160"
				fill="none"
				stroke="url(#exploreLineGrad)"
				stroke-width="1"
			/>
			<path
				class="explore-line l2"
				d="M20 220 C 200 180, 340 260, 520 220 S 720 140, 780 200"
				fill="none"
				stroke="url(#exploreLineGrad)"
				stroke-width="1"
			/>
			<path
				class="explore-line l3"
				d="M40 280 C 220 260, 380 300, 560 270 S 720 240, 780 270"
				fill="none"
				stroke="url(#exploreLineGrad)"
				stroke-width="1"
			/>
			<g class="explore-particles" fill="rgba(180,220,255,0.55)">
				<circle cx="90" cy="50" r="1.4" />
				<circle cx="220" cy="180" r="1.2" />
				<circle cx="360" cy="80" r="1.6" />
				<circle cx="500" cy="220" r="1.1" />
				<circle cx="640" cy="120" r="1.3" />
				<circle cx="720" cy="240" r="1.2" />
			</g>
		</svg>

		<ol class="explore-grid">
			{
				themes.map((theme) => (
					<li class="explore-card" tabindex="0">
						<div class="explore-icon" aria-hidden="true">
							<Icon icon={theme.icon} color="var(--accent-regular)" size="1.5rem" gradient />
						</div>
						<h3 class="explore-card-title">{theme.title}</h3>
						<p class="explore-card-desc">{theme.description}</p>
						<ul class="explore-tags">
							{theme.tags.map((tag) => (
								<li>{tag}</li>
							))}
						</ul>
						<span class="explore-cta" aria-hidden="true">
							Explore <span class="explore-arrow">→</span>
						</span>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.explore {
		position: relative;
		padding: 1rem 0 2rem;
	}

	.explore-header {
		margin: 0 0 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.explore-eyebrow {
		margin: 0;
		font-size: var(--text-base);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.explore-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.explore-intro {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-md);
		line-height: 1.7;
	}

	/* --------- Connection field (decorative background) --------- */

	.explore-grid-wrapper {
		position: relative;
	}

	.explore-connections {
		position: absolute;
		inset: -1.5rem -1rem;
		width: calc(100% + 2rem);
		height: calc(100% + 3rem);
		z-index: 0;
		pointer-events: none;
		opacity: 0.55;
	}

	.explore-line {
		stroke-dasharray: 4 8;
		stroke-dashoffset: 0;
		animation: explore-line-drift 24s linear infinite;
	}
	.explore-line.l2 {
		animation-duration: 30s;
		animation-direction: reverse;
	}
	.explore-line.l3 {
		animation-duration: 36s;
		animation-delay: -6s;
	}

	.explore-particles circle {
		animation: explore-particle-drift 16s ease-in-out infinite;
	}
	.explore-particles circle:nth-child(2) { animation-duration: 19s; animation-delay: -3s; }
	.explore-particles circle:nth-child(3) { animation-duration: 22s; animation-delay: -6s; }
	.explore-particles circle:nth-child(4) { animation-duration: 18s; animation-delay: -1s; }
	.explore-particles circle:nth-child(5) { animation-duration: 24s; animation-delay: -8s; }
	.explore-particles circle:nth-child(6) { animation-duration: 21s; animation-delay: -4s; }

	@keyframes explore-line-drift {
		to { stroke-dashoffset: -80; }
	}

	@keyframes explore-particle-drift {
		0%, 100% { transform: translate(0, 0); opacity: 0.5; }
		50%      { transform: translate(4px, -6px); opacity: 0.9; }
	}

	/* --------- Grid + cards --------- */

	.explore-grid {
		position: relative;
		z-index: 1;
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.15rem;
	}

	/* Tablet: 2 per row */
	@media (min-width: 40em) {
		.explore-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Desktop: 3 on first row, 2 centered on second row (6-track scaffold) */
	@media (min-width: 60em) {
		.explore-grid {
			grid-template-columns: repeat(6, 1fr);
		}
		.explore-card {
			grid-column: span 2;
		}
		.explore-card:nth-child(4) {
			grid-column: 2 / span 2;
		}
		.explore-card:nth-child(5) {
			grid-column: 4 / span 2;
		}
	}

	.explore-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		border-radius: 1.25rem;
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.25)
		);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		cursor: default;
		transition:
			transform var(--theme-transition),
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	/* Radial wash that lights up on hover */
	.explore-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 85% -10%,
			hsla(187, 85%, 53%, 0.16),
			transparent 55%
		);
		opacity: 0;
		transition: opacity var(--theme-transition);
		pointer-events: none;
	}

	.explore-card:hover,
	.explore-card:focus-visible,
	.explore-card:focus-within {
		transform: translateY(-3px);
		border-color: hsla(187, 85%, 53%, 0.42);
		box-shadow: var(--shadow-md);
		outline: none;
	}
	.explore-card:hover::before,
	.explore-card:focus-visible::before,
	.explore-card:focus-within::before {
		opacity: 1;
	}

	.explore-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.75rem;
		background: hsla(187, 85%, 53%, 0.10);
		border: 1px solid hsla(187, 85%, 53%, 0.22);
	}

	.explore-card-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.explore-card-desc {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-sm);
		line-height: 1.55;
	}

	.explore-tags {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.explore-tags li {
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gray-400);
		padding: 0.22rem 0.55rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: hsla(var(--gray-999-basis), 0.25);
	}

	.explore-cta {
		margin-top: auto;
		padding-top: 0.35rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		opacity: 0.55;
		transition:
			opacity var(--theme-transition),
			color var(--theme-transition);
	}

	.explore-arrow {
		display: inline-block;
		transition: transform var(--theme-transition);
	}

	.explore-card:hover .explore-cta,
	.explore-card:focus-visible .explore-cta,
	.explore-card:focus-within .explore-cta {
		opacity: 1;
		color: var(--accent-regular);
	}
	.explore-card:hover .explore-arrow,
	.explore-card:focus-visible .explore-arrow,
	.explore-card:focus-within .explore-arrow {
		transform: translateX(4px);
	}

	@media (prefers-reduced-motion: reduce) {
		.explore-line,
		.explore-particles circle,
		.explore-card,
		.explore-cta,
		.explore-arrow,
		.explore-card::before {
			animation: none !important;
			transition: none !important;
		}
	}

	@media (min-width: 50em) {
		.explore {
			padding: 2rem 0 4rem;
		}
	}
</style>

