---
import { iconPaths } from './IconPaths';
import { timelineData } from '../data/timeline';

type Pt = { x: number; y: number };

const CANVAS_W = 1320;
const CANVAS_H = 460;
const CARD_TOP = 540;

// Snaking premium path: Today (left) -> 2001 (right).
const points: Pt[] = timelineData.map((_, i) => ({
	x: 88 + i * ((CANVAS_W - 176) / Math.max(timelineData.length - 1, 1)),
	y: [126, 282, 142, 296, 152, 286, 154, 278, 160][i] ?? 180,
}));

const iconMap = Object.fromEntries(timelineData.map((d) => [d.id, iconPaths[d.icon]]));

function smoothPath(pts: Pt[]): string {
	if (pts.length < 2) return '';
	let d = `M ${pts[0].x.toFixed(2)} ${pts[0].y.toFixed(2)}`;
	for (let i = 0; i < pts.length - 1; i++) {
		const p0 = pts[i - 1] ?? pts[i];
		const p1 = pts[i];
		const p2 = pts[i + 1];
		const p3 = pts[i + 2] ?? p2;
		const cp1x = p1.x + (p2.x - p0.x) / 6;
		const cp1y = p1.y + (p2.y - p0.y) / 6;
		const cp2x = p2.x - (p3.x - p1.x) / 6;
		const cp2y = p2.y - (p3.y - p1.y) / 6;
		d += ` C ${cp1x.toFixed(2)} ${cp1y.toFixed(2)}, ${cp2x.toFixed(2)} ${cp2y.toFixed(2)}, ${p2.x.toFixed(2)} ${p2.y.toFixed(2)}`;
	}
	return d;
}

const pathD = smoothPath(points);
---

<section class="jr" aria-labelledby="jr-title" data-journey>
	<div class="jr-left">
		<p class="jr-eyebrow">Journey</p>
		<h2 id="jr-title" class="jr-title">Experience &amp; Education</h2>
		<p class="jr-sub">
			A roadmap from today back to the beginning of my scientific and engineering journey.
		</p>
		<p class="jr-help">Click any milestone to explore that chapter.</p>
	</div>

	<div class="jr-right">
		<div class="jr-roadmap" data-roadmap>
			<svg
				class="jr-svg"
				viewBox={`0 0 ${CANVAS_W} ${CANVAS_H}`}
				preserveAspectRatio="xMidYMid meet"
				aria-hidden="true"
			>
				<defs>
					<linearGradient id="jrPathGrad" x1="0" y1="0" x2="1" y2="0">
						<stop offset="0%" stop-color="hsla(187, 85%, 60%, 0.95)" />
						<stop offset="55%" stop-color="hsla(210, 85%, 65%, 0.8)" />
						<stop offset="100%" stop-color="hsla(265, 80%, 70%, 0.65)" />
					</linearGradient>
					<filter id="jrPathGlow" x="-30%" y="-30%" width="160%" height="160%">
						<feGaussianBlur stdDeviation="2.5" result="blur" />
						<feMerge>
							<feMergeNode in="blur" />
							<feMergeNode in="SourceGraphic" />
						</feMerge>
					</filter>
				</defs>
				<path class="jr-path-glow" d={pathD} fill="none" />
				<path class="jr-path" d={pathD} fill="none" />
			</svg>

			<div class="jr-mobile-rail" aria-hidden="true"></div>

			{
				timelineData.map((entry, i) => {
					const p = points[i];
					return (
						<button
							type="button"
							class:list={['jr-node', { 'is-current': entry.current }]}
							data-node-id={entry.id}
							data-index={i}
							style={`--x:${p.x}px;--y:${p.y}px;--i:${i};`}
							aria-controls="jr-card"
							aria-expanded="false"
							aria-label={`${entry.year}: ${entry.title}${entry.organization ? `, ${entry.organization}` : ''}`}
						>
							<span class="jr-year">{entry.year}</span>
							<span class="jr-dot" aria-hidden="true"></span>
						</button>
					);
				})
			}

			<div class="jr-connector" aria-hidden="true"></div>
		</div>

		<article class="jr-card" id="jr-card" role="region" aria-live="polite">
			<header class="jr-card-head">
				<span class="jr-card-icon" data-card-icon aria-hidden="true"></span>
				<div class="jr-card-heading">
					<p class="jr-card-year" data-card-year></p>
					<h3 class="jr-card-title" data-card-title></h3>
					<p class="jr-card-org" data-card-org></p>
				</div>
			</header>

			<p class="jr-card-desc" data-card-desc></p>
			<ul class="jr-card-tags" data-card-tags></ul>
			<a class="jr-card-cta" data-card-cta hidden href="#">
				View Details <span aria-hidden="true">→</span>
			</a>
		</article>
	</div>
</section>

<script define:vars={{ journey: timelineData, icons: iconMap, canvasHeight: CANVAS_H, cardTop: CARD_TOP }}>
	const roots = document.querySelectorAll('[data-journey]');

	for (const root of roots) {
		const roadmap = root.querySelector('.jr-roadmap');
		const path = root.querySelector('.jr-path');
		const nodes = Array.from(root.querySelectorAll('.jr-node'));
		const connector = root.querySelector('.jr-connector');

		const yearEl = root.querySelector('[data-card-year]');
		const titleEl = root.querySelector('[data-card-title]');
		const orgEl = root.querySelector('[data-card-org]');
		const descEl = root.querySelector('[data-card-desc]');
		const tagsEl = root.querySelector('[data-card-tags]');
		const ctaEl = root.querySelector('[data-card-cta]');
		const iconEl = root.querySelector('[data-card-icon]');
		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const renderIcon = (id) => {
			const iconPath = icons[id] || '';
			return `
			<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 256 256" aria-hidden="true" stroke="url(#jrIconGrad)" fill="url(#jrIconGrad)" style="width:1.35rem;height:1.35rem;">
				<defs>
					<linearGradient id="jrIconGrad" x1="23" x2="235" y1="43" y2="202" gradientUnits="userSpaceOnUse">
						<stop stop-color="var(--gradient-stop-1)" />
						<stop offset=".5" stop-color="var(--gradient-stop-2)" />
						<stop offset="1" stop-color="var(--gradient-stop-3)" />
					</linearGradient>
				</defs>
				<g>${iconPath}</g>
			</svg>`;
		};

		const updateCard = (item) => {
			if (!yearEl || !titleEl || !orgEl || !descEl || !tagsEl || !iconEl) return;

			root.classList.remove('is-card-open');
			void root.offsetWidth;

			yearEl.textContent = item.year;
			titleEl.textContent = item.title;
			orgEl.textContent = item.organization || '';
			orgEl.hidden = !item.organization;
			descEl.textContent = item.description;
			iconEl.innerHTML = renderIcon(item.id);

			tagsEl.innerHTML = '';
			for (const tag of item.tags || []) {
				const li = document.createElement('li');
				li.textContent = tag;
				tagsEl.appendChild(li);
			}

			if (ctaEl) {
				if (item.href) {
					ctaEl.hidden = false;
					ctaEl.href = item.href;
				} else {
					ctaEl.hidden = true;
				}
			}

			root.classList.add('is-card-open');
		};

		const updateConnector = (button) => {
			if (!roadmap || !connector || !button) return;
			const rRect = roadmap.getBoundingClientRect();
			const bRect = button.getBoundingClientRect();
			const x = bRect.left + bRect.width / 2 - rRect.left;
			const y = bRect.top + bRect.height / 2 - rRect.top;

			connector.style.setProperty('--cx', `${x}px`);
			connector.style.setProperty('--cy', `${y + 18}px`);
			connector.style.setProperty('--ch', `${Math.max(cardTop - (y + 18), 28)}px`);
			connector.classList.add('is-on');
		};

		const activate = (index) => {
			const item = journey[index];
			const node = nodes[index];
			if (!item || !node) return;

			nodes.forEach((n) => {
				n.classList.remove('is-active');
				n.setAttribute('aria-expanded', 'false');
			});

			node.classList.add('is-active');
			node.setAttribute('aria-expanded', 'true');
			updateCard(item);
			updateConnector(node);
		};

		nodes.forEach((node, idx) => {
			node.addEventListener('click', () => activate(idx));
			node.addEventListener('keydown', (event) => {
				const key = event.key;
				if (key === 'ArrowRight' || key === 'ArrowDown') {
					event.preventDefault();
					nodes[(idx + 1) % nodes.length]?.focus();
				} else if (key === 'ArrowLeft' || key === 'ArrowUp') {
					event.preventDefault();
					nodes[(idx - 1 + nodes.length) % nodes.length]?.focus();
				} else if (key === 'Home') {
					event.preventDefault();
					nodes[0]?.focus();
				} else if (key === 'End') {
					event.preventDefault();
					nodes[nodes.length - 1]?.focus();
				} else if (key === 'Enter' || key === ' ') {
					event.preventDefault();
					activate(idx);
				}
			});
		});

		if (path) {
			try {
				const len = path.getTotalLength();
				path.style.strokeDasharray = `${len}`;
				path.style.strokeDashoffset = `${len}`;
			} catch {
				/* no-op */
			}
		}

		const reveal = () => {
			root.classList.add('is-revealed');
			if (path) path.style.strokeDashoffset = '0';
		};

		if (prefersReduced || !('IntersectionObserver' in window)) {
			reveal();
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							reveal();
							observer.disconnect();
							break;
						}
					}
				},
				{ threshold: 0.2, rootMargin: '0px 0px -10% 0px' },
			);
			observer.observe(root);
		}

		window.addEventListener('resize', () => {
			const active = root.querySelector('.jr-node.is-active');
			if (active) updateConnector(active);
		});

		activate(0);
	}
</script>

<style>
	.jr {
		display: grid;
		grid-template-columns: minmax(20rem, 34%) minmax(0, 66%);
		gap: 2rem;
		align-items: start;
	}

	.jr-left {
		position: sticky;
		top: 6rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		width: 100%;
	}

	.jr-eyebrow {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.jr-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: clamp(var(--text-3xl), 3.4vw, var(--text-5xl));
		line-height: 1.05;
		color: var(--gray-0);
		font-weight: 600;
		max-width: none;
	}

	.jr-sub {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-md);
		line-height: 1.65;
		max-width: none;
	}

	.jr-help {
		margin: 0.15rem 0 0;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.jr-right {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.jr-roadmap {
		position: relative;
		width: min(1320px, 100%);
		height: 620px;
		margin-inline: auto;
	}

	.jr-svg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 460px;
	}

	.jr-path-glow {
		stroke: url(#jrPathGrad);
		stroke-width: 5.5;
		opacity: 0.26;
		filter: url(#jrPathGlow);
		stroke-linecap: round;
	}

	.jr-path {
		stroke: url(#jrPathGrad);
		stroke-width: 2.2;
		stroke-linecap: round;
		transition: stroke-dashoffset 1.9s ease-out;
	}

	.jr-node {
		position: absolute;
		left: var(--x);
		top: var(--y);
		transform: translate(-50%, -50%) scale(0.95);
		border: 0;
		background: transparent;
		padding: 0;
		cursor: pointer;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.55rem;
		opacity: 0;
		transition:
			opacity 0.55s ease,
			transform 0.45s ease;
		transition-delay: calc(var(--i) * 80ms + 180ms);
	}

	.jr-year {
		font-family: var(--font-brand);
		font-size: 0.84rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--gray-200);
		white-space: nowrap;
	}

	.jr-dot {
		position: relative;
		width: 2.15rem;
		height: 2.15rem;
		border-radius: 999rem;
		background: radial-gradient(circle at 40% 30%, hsla(187, 85%, 70%, 0.6), hsla(187, 85%, 45%, 0.25));
		border: 1px solid hsla(187, 85%, 68%, 0.62);
		box-shadow:
			0 0 0 6px hsla(var(--gray-999-basis), 0.62),
			0 0 24px -2px hsla(187, 85%, 65%, 0.7),
			0 0 38px -8px hsla(265, 80%, 70%, 0.6);
		transition:
			transform var(--theme-transition),
			box-shadow var(--theme-transition),
			border-color var(--theme-transition);
	}

	.jr-dot::before {
		content: '';
		position: absolute;
		inset: 28%;
		border-radius: 999rem;
		background: hsla(187, 85%, 82%, 0.95);
	}

	.jr-node:hover .jr-dot,
	.jr-node:focus-visible .jr-dot {
		transform: scale(1.11);
		border-color: hsla(187, 85%, 82%, 0.95);
		box-shadow:
			0 0 0 6px hsla(var(--gray-999-basis), 0.62),
			0 0 28px 0 hsla(187, 85%, 68%, 0.95),
			0 0 45px -6px hsla(265, 80%, 72%, 0.75);
	}

	.jr-node:focus-visible {
		outline: none;
	}

	.jr-node:focus-visible .jr-dot {
		box-shadow:
			0 0 0 6px hsla(var(--gray-999-basis), 0.62),
			0 0 0 9px hsla(187, 85%, 70%, 0.5),
			0 0 30px 0 hsla(187, 85%, 70%, 0.95),
			0 0 46px -6px hsla(265, 80%, 72%, 0.75);
	}

	.jr-node.is-active .jr-dot {
		border-color: hsla(187, 85%, 84%, 0.98);
		box-shadow:
			0 0 0 6px hsla(var(--gray-999-basis), 0.62),
			0 0 34px 0 hsla(187, 85%, 72%, 0.95),
			0 0 52px -4px hsla(265, 80%, 74%, 0.88);
	}

	.jr-node.is-active .jr-dot::after {
		content: '';
		position: absolute;
		inset: -8px;
		border-radius: 999rem;
		border: 1px solid hsla(187, 85%, 70%, 0.72);
		animation: jr-pulse 2.4s ease-out infinite;
	}

	@keyframes jr-pulse {
		0% { transform: scale(1); opacity: 0.9; }
		100% { transform: scale(1.62); opacity: 0; }
	}

	.jr.is-revealed .jr-node {
		opacity: 1;
		transform: translate(-50%, -50%) scale(1);
	}

	.jr-connector {
		position: absolute;
		left: var(--cx, 0px);
		top: var(--cy, 0px);
		width: 1px;
		height: var(--ch, 0px);
		opacity: 0;
		transform: translateX(-50%);
		background: linear-gradient(
			180deg,
			hsla(187, 85%, 72%, 0.75),
			hsla(210, 85%, 68%, 0.55),
			hsla(265, 80%, 72%, 0.35),
			transparent
		);
		box-shadow: 0 0 14px hsla(187, 85%, 70%, 0.5);
		transition: opacity 0.35s ease;
		pointer-events: none;
	}

	.jr-connector.is-on {
		opacity: 1;
	}

	.jr-card {
		position: absolute;
		top: 510px;
		left: 50%;
		transform: translateX(-50%) translateY(12px);
		width: min(700px, calc(100% - 1.25rem));
		padding: 1.6rem 1.7rem;
		border-radius: 1.2rem;
		border: 1px solid hsla(210, 80%, 70%, 0.24);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.64),
			hsla(var(--gray-999-basis), 0.28)
		);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		box-shadow:
			var(--shadow-md),
			0 0 40px -14px hsla(187, 85%, 64%, 0.52);
		opacity: 0.82;
		filter: blur(1.5px);
		transition:
			opacity 0.34s ease,
			transform 0.34s ease,
			filter 0.34s ease;
	}

	.jr.is-card-open .jr-card {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
		filter: blur(0);
	}

	.jr-card-head {
		display: flex;
		gap: 0.85rem;
		align-items: flex-start;
	}

	.jr-card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.75rem;
		background: hsla(187, 85%, 53%, 0.10);
		border: 1px solid hsla(187, 85%, 53%, 0.3);
		flex-shrink: 0;
	}

	.jr-card-heading {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.jr-card-year {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		letter-spacing: 0.17em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.jr-card-title {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.jr-card-org {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-sm);
	}

	.jr-card-desc {
		margin: 0.8rem 0 0;
		color: var(--gray-200);
		font-size: var(--text-base);
		line-height: 1.62;
	}

	.jr-card-tags {
		list-style: none;
		padding: 0;
		margin: 0.9rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.jr-card-tags li {
		font-size: 0.74rem;
		letter-spacing: 0.04em;
		color: var(--gray-100);
		padding: 0.28rem 0.65rem;
		border-radius: 999rem;
		border: 1px solid hsla(187, 85%, 53%, 0.32);
		background: hsla(187, 85%, 53%, 0.07);
	}

	.jr-card-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 0.9rem;
		color: var(--accent-regular);
		text-decoration: none;
		font-size: var(--text-sm);
	}

	.jr-card-cta:hover,
	.jr-card-cta:focus-visible {
		text-decoration: underline;
	}

	.jr-mobile-rail {
		display: none;
	}

	@media (max-width: 70em) {
		.jr {
			grid-template-columns: 1fr;
			gap: 1.4rem;
		}

		.jr-left {
			position: static;
		}

		.jr-roadmap {
			height: 640px;
		}
	}

	@media (max-width: 60em) {
		.jr-roadmap {
			height: auto;
			padding-left: 2.6rem;
			padding-bottom: 0.4rem;
		}

		.jr-svg,
		.jr-connector {
			display: none;
		}

		.jr-mobile-rail {
			display: block;
			position: absolute;
			top: 0.8rem;
			bottom: 0.4rem;
			left: 1.45rem;
			width: 1px;
			background: linear-gradient(
				180deg,
				transparent,
				hsla(187, 85%, 60%, 0.42) 15%,
				hsla(210, 85%, 65%, 0.42) 50%,
				hsla(265, 80%, 70%, 0.42) 85%,
				transparent
			);
		}

		.jr-node {
			position: relative;
			left: auto;
			top: auto;
			transform: translateY(6px);
			flex-direction: row;
			justify-content: flex-start;
			gap: 0.75rem;
			margin: 0.62rem 0;
		}

		.jr.is-revealed .jr-node {
			transform: translateY(0);
		}

		.jr-year {
			order: 2;
		}

		.jr-card {
			position: relative;
			top: auto;
			left: auto;
			transform: translateY(10px);
			width: 100%;
			margin-top: 0.7rem;
		}

		.jr.is-card-open .jr-card {
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.jr-path,
		.jr-node,
		.jr-card,
		.jr-dot {
			transition: none !important;
		}

		.jr-node,
		.jr.is-revealed .jr-node {
			opacity: 1 !important;
			transform: translate(-50%, -50%) !important;
		}

		@media (max-width: 60em) {
			.jr-node,
			.jr.is-revealed .jr-node {
				transform: none !important;
			}
		}

		.jr-path {
			stroke-dashoffset: 0 !important;
		}

		.jr-node.is-active .jr-dot::after {
			animation: none;
		}

		.jr-card {
			filter: none;
			opacity: 1;
		}
	}
</style>

