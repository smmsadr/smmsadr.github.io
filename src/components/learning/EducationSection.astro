---
import Section from './Section.astro';
import type { Education } from '../../data/learning/education';

export interface Props {
	items: Education[];
}

const { items } = Astro.props;
---

<Section
	id="education"
	eyebrow="Education"
	title="Formal Education"
	description="The academic threads — physics, computer science, and quantum computing — that keep looping back into everything I build."
>
	<ol class="ld-edu">
		{
			items.map((entry) => (
				<li class="ld-edu-card">
					<article>
						<p class="ld-edu-period">{entry.period}{entry.status ? ` · ${entry.status}` : ''}</p>
						<h3 class="ld-edu-degree">
							{entry.href ? (
								<a href={entry.href}>{entry.degree}</a>
							) : (
								entry.degree
							)}
						</h3>
						{entry.field && <p class="ld-edu-field">{entry.field}</p>}
						<p class="ld-edu-institution">
							{entry.institution}
							{entry.location ? ` · ${entry.location}` : ''}
						</p>
						<p class="ld-edu-summary">{entry.summary}</p>
					</article>
				</li>
			))
		}
	</ol>
</Section>

<style>
	.ld-edu {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.ld-edu-card {
		position: relative;
		padding: 1.25rem 1.25rem;
		border-radius: 1rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.24)
		);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: var(--shadow-sm);
	}

	.ld-edu-period {
		margin: 0 0 0.35rem;
		font-family: var(--font-brand);
		font-size: 0.7rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent-regular);
	}

	.ld-edu-degree {
		margin: 0 0 0.15rem;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.ld-edu-degree a {
		color: inherit;
		text-decoration: none;
	}

	.ld-edu-degree a:hover,
	.ld-edu-degree a:focus-visible {
		color: var(--accent-regular);
		outline: none;
	}

	.ld-edu-field {
		margin: 0 0 0.4rem;
		font-family: var(--font-brand);
		font-size: 0.85rem;
		color: var(--accent-regular);
	}

	.ld-edu-institution {
		margin: 0 0 0.6rem;
		font-size: 0.9rem;
		color: var(--gray-300);
	}

	.ld-edu-summary {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--gray-100);
	}

	@media (min-width: 50em) {
		.ld-edu {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.25rem;
		}
	}
</style>

