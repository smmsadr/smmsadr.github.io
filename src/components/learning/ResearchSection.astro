---
import Section from './Section.astro';
import type { ResearchVision } from '../../data/learning/research';

export interface Props {
	vision: ResearchVision;
}

const { vision } = Astro.props;
---

<Section
	id="research"
	eyebrow="Research Vision"
	title="Where the questions live"
	description={vision.statement}
>
	<ol class="ld-research">
		{
			vision.pillars.map((pillar) => (
				<li class="ld-pillar">
					<h3 class="ld-pillar-title">{pillar.title}</h3>
					<p class="ld-pillar-summary">{pillar.summary}</p>
					{pillar.keywords && pillar.keywords.length > 0 && (
						<p class="ld-pillar-keywords">
							{pillar.keywords.map((k) => (
								<span>{k}</span>
							))}
						</p>
					)}
				</li>
			))
		}
	</ol>
</Section>

<style>
	.ld-research {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.ld-pillar {
		padding: 1.25rem;
		border-radius: 1rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.24)
		);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: var(--shadow-sm);
	}

	.ld-pillar-title {
		margin: 0 0 0.5rem;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.2;
		color: var(--gray-0);
		font-weight: 600;
	}

	.ld-pillar-summary {
		margin: 0 0 0.6rem;
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--gray-100);
	}

	.ld-pillar-keywords {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0 0.4rem;
		row-gap: 0.25rem;
		font-family: var(--font-brand);
		font-size: 0.78rem;
		letter-spacing: 0.05em;
		color: var(--gray-300);
	}

	.ld-pillar-keywords span + span::before {
		content: '·';
		margin-right: 0.4rem;
		color: var(--accent-regular);
		opacity: 0.75;
	}

	@media (min-width: 50em) {
		.ld-research {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.25rem;
		}
	}
</style>

