---
import Section from './Section.astro';
import type { Recognition } from '../../data/learning/recognition';

export interface Props {
	items: Recognition[];
}

const { items } = Astro.props;
---

<Section
	id="recognition"
	eyebrow="Awards & Recognition"
	title="External signals"
	description="Talks, endorsements, and community recognition that reflect the work's reach beyond the day-to-day."
>
	<ol class="ld-rec">
		{
			items.map((r) => (
				<li class="ld-rec-card">
					<article>
						<p class="ld-rec-meta">
							{r.year && <span class="ld-rec-year">{r.year}</span>}
							{r.year && r.category && <span class="ld-rec-sep" aria-hidden="true">·</span>}
							{r.category && <span class="ld-rec-cat">{r.category}</span>}
						</p>
						<h3 class="ld-rec-title">
							{r.url ? <a href={r.url} rel="noopener noreferrer">{r.title}</a> : r.title}
						</h3>
						{r.issuer && <p class="ld-rec-issuer">{r.issuer}</p>}
						{r.summary && <p class="ld-rec-summary">{r.summary}</p>}
					</article>
				</li>
			))
		}
	</ol>
</Section>

<style>
	.ld-rec {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.ld-rec-card {
		padding: 1.15rem 1.25rem;
		border-radius: 1rem;
		border: 1px solid hsla(210, 80%, 70%, 0.14);
		background: linear-gradient(
			180deg,
			hsla(var(--gray-999-basis), 0.55),
			hsla(var(--gray-999-basis), 0.24)
		);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: var(--shadow-sm);
	}

	.ld-rec-meta {
		margin: 0 0 0.35rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.5rem;
		font-family: var(--font-brand);
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.ld-rec-year { color: var(--accent-regular); font-weight: 600; }
	.ld-rec-sep  { color: var(--gray-500); }
	.ld-rec-cat  { color: var(--gray-300); }

	.ld-rec-title {
		margin: 0 0 0.25rem;
		font-family: var(--font-brand);
		font-size: var(--text-md);
		line-height: 1.25;
		color: var(--gray-0);
		font-weight: 600;
	}

	.ld-rec-title a {
		color: inherit;
		text-decoration: none;
	}
	.ld-rec-title a:hover,
	.ld-rec-title a:focus-visible {
		color: var(--accent-regular);
	}

	.ld-rec-issuer {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		color: var(--gray-300);
	}

	.ld-rec-summary {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--gray-100);
	}

	@media (min-width: 50em) {
		.ld-rec {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.25rem;
		}
	}
</style>

