</section>

<style>
	.why-deep {
		position: relative;
		padding: 2rem 0;
	}

	.why-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
	}

	.why-eyebrow {
		margin: 0;
		font-size: var(--text-sm);
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #7dd3fc;
	}

	.why-title {
		margin: 0;
		font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
		line-height: 1.2;
		color: var(--gray-0);
		max-width: 26ch;
	}

	.why-body p {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-md);
		line-height: 1.8;
		max-width: 60ch;
	}

	.why-body p + p {
		margin-top: 1.15rem;
	}

	/* Visual */
	.why-visual {
		margin: 0;
	}

	.visual-frame {
		position: relative;
		border-radius: 1.75rem;
		overflow: hidden;
		border: 1px solid hsla(210, 80%, 70%, 0.15);
		background: linear-gradient(180deg, hsla(var(--gray-999-basis), 0.5), hsla(var(--gray-999-basis), 0.2));
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-md);
	}

	.visual-svg {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 4 / 5;
	}

	.visual-quote {
		position: absolute;
		left: 1.25rem;
		right: 1.25rem;
		bottom: 1.25rem;
		padding: 1rem 1.15rem;
		border-radius: 1rem;
