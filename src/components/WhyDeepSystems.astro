						<g class="fish" transform="translate(140 380)">
							<g class="fish-body">
								<ellipse cx="4" cy="0" rx="4" ry="1.8" fill="rgba(160,190,215,0.55)" />
								<polygon points="8,0 11,-2.5 11,2.5" fill="rgba(160,190,215,0.55)" />
