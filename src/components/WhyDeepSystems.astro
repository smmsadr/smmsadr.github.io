								<!-- Gill lines -->
								<line x1="-25" y1="-4" x2="-25" y2="2" stroke="rgba(170,190,215,0.35)" stroke-width="0.4" />
								<line x1="-22" y1="-4" x2="-22" y2="2" stroke="rgba(170,190,215,0.35)" stroke-width="0.4" />
							</g>
						</g>
					</g>

					<!-- Technical diver with twin tanks -->
					<g class="diver" transform="translate(40 335)">
