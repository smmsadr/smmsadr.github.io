								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<g class="qnn-node" transform="translate(320 303)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
