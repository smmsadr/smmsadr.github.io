							</g>
						</g>
						<g class="fish" transform="translate(95 375)">
							<g class="fish-body">
								<ellipse cx="4" cy="0" rx="4" ry="1.8" fill="rgba(160,190,215,0.55)" />
								<polygon points="8,0 11,-2.5 11,2.5" fill="rgba(160,190,215,0.55)" />
								<circle cx="1.5" cy="-0.4" r="0.5" fill="rgba(255,255,255,0.6)" />
							</g>
						</g>

						<!-- Shark (silhouette, facing left) -->
						<g class="shark" transform="translate(235 405)">
							<g class="shark-body">
								<!-- Body -->
								<path d="M -45 0
									C -40 -6, -20 -10, 5 -9
									C 20 -8, 30 -6, 38 -4
									L 55 -12
									L 46 0
									L 55 12
									L 38 4
									C 30 6, 20 8, 5 9
