						<circle cx="22" cy="14" r="2.5" fill="#a855f7" />
						<circle cx="-22" cy="14" r="2.5" fill="#22d3ee" />
					</g>

					<!-- Marine life: small fish + shark silhouette -->
					<g class="marine-life" aria-hidden="true">
