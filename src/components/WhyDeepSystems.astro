							<rect x="8" y="-8" width="24" height="5" rx="2.5"
								fill="rgba(180,205,230,0.45)"
								stroke="rgba(220,235,250,0.75)" stroke-width="0.6" />
							<!-- Tank valves (right end) -->
							<line x1="30" y1="-12" x2="30" y2="-8"
								stroke="rgba(220,235,250,0.75)" stroke-width="0.8" />
							<line x1="32" y1="-8"  x2="32" y2="-3"
								stroke="rgba(220,235,250,0.75)" stroke-width="0.8" />
							<!-- Manifold band connecting tank ends -->
							<line x1="8" y1="-7" x2="32" y2="-7"
								stroke="rgba(220,235,250,0.35)" stroke-width="0.4" />
							<!-- Regulator hose from tank valve to mask -->
							<path d="M32 -3 C 34 -1, 36 -1, 38 -1"
								fill="none" stroke="rgba(210,230,250,0.55)" stroke-width="0.8" />
							<!-- Torso -->
							<path d="M6 -6 C 18 -8, 28 -4, 34 2 C 36 4, 36 8, 34 10 C 24 10, 14 6, 6 4 Z"
								fill="rgba(140,170,210,0.55)"
								stroke="rgba(200,220,240,0.65)" stroke-width="0.6" />
