							<line x1="210" y1="350" x2="320" y2="303" />
							<line x1="210" y1="350" x2="320" y2="350" />
						</g>

						<!-- Qubit nodes (mini Bloch-sphere styling) -->
						<g class="qnn-nodes">
							<!-- Layer 0 (3 qubits) -->
							<g class="qnn-node" transform="translate(100 210)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<g class="qnn-node" transform="translate(100 280)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<g class="qnn-node" transform="translate(100 350)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<!-- Layer 1 (5 qubits) -->
							<g class="qnn-node" transform="translate(210 210)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<g class="qnn-node" transform="translate(210 245)">
								<circle r="5.6" fill="rgba(10,20,40,0.78)" stroke="#7dd3fc" stroke-width="1" />
								<ellipse rx="5.6" ry="1.9" fill="none" stroke="rgba(168,85,247,0.55)" stroke-width="0.5" />
								<ellipse rx="1.9" ry="5.6" fill="none" stroke="rgba(168,85,247,0.35)" stroke-width="0.5" />
								<circle r="1.05" fill="#c4b5fd" />
							</g>
							<g class="qnn-node" transform="translate(210 280)">
