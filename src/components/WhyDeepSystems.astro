									stroke="rgba(170,190,215,0.35)" stroke-width="0.5" />
								<!-- Pectoral fin -->
								<path d="M -15 4 L -5 12 L 2 6 Z"
									fill="rgba(70,90,120,0.55)"
									stroke="rgba(170,190,215,0.35)" stroke-width="0.5" />
								<!-- Eye -->
